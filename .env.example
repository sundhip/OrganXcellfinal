# ═══════════════════════════════════════════════════════════
# OrganXcell — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── PostgreSQL ───────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://organxcell:organxcell123@localhost:5432/organxcell

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:8080

# ── Claude AI (REQUIRED for AI features) ─────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (optional — for notifications) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# ── Twilio SMS (optional) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Google Maps (optional — Leaflet works without it) ─────
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
